# Backend API target for local Vite proxy
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
VITE_API_TARGET=http://localhost:5004

# Optional production API origin for frontend requests.
# Leave unset in local development to keep using "/api" with the Vite proxy.
# Example:
# VITE_API_BASE_URL=https://your-backend.onrender.com
# The frontend also tolerates a value that already ends with /api.
